{
  "name": "design-system-2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "styles:build": "sass packages/design-system/src/styles.scss packages/design-system/src/styles.css --no-source-map",
    "dev": "npm run styles:build && next dev",
    "start": "next start",
    "lint": "eslint",
    "build": "npm run styles:build && next build",
    "build:static": "npm run styles:build && set STATIC_EXPORT=true&& next build",
    "deploy": "gh-pages -d out"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sass": "^1.97.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "gh-pages": "^6.3.0",
    "typescript": "^5"
  }
}
